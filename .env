# Configuration for Ollama LLM provider
# Optimized settings for i7 8-thread 16GB RAM

# Ollama provider settings
OLM_MODEL=qwen2.5-coder:7b
OLM_MAX_TOKENS=4096

# Execution monitoring settings
MONITORING_ENABLED=true
MONITORING_LOG_LEVEL=info
MONITORING_INTERVAl=5s

# Agent planning settings
AGENT_PLANNING_ENABLED=true
AGENT_PLANNING_ALGORITHM=greedy
AGENT_PLANNING_TIMEOUT=10s

# Resource optimization settings
RESOURCE_MAX_CPU=8
RESOURCE_MAX_RAM=16000

# Search engine settings
SEARCH_ENGINE_ENABLED=true
SEARCH_ENGINE_TYPE=custom
SEARCH_ENGINE_API_URL=https://api.example.com/search
